			"name": "[concat(parameters('factoryName'), '/dw_vacunacion')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('dw_vacunacion_properties_typeProperties_server')]",
					"database": "[parameters('dw_vacunacion_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('dw_vacunacion_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('dw_vacunacion_password')]"
					}
				}
			},
			"dependsOn": []
