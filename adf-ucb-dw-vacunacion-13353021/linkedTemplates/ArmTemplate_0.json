		},
		"datalake_vacunacion_connectionString": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"connectionString\"de \"datalake_vacunacion\""
		},
		"dw_vacunacion_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"dw_vacunacion\""
		},
