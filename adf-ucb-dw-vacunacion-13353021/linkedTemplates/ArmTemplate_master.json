{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "adf-ucb-dw-vacunacion-13353021"
		},
		"datalake_vacunacion_connectionString": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"connectionString\"de \"datalake_vacunacion\""
		},
		"dw_vacunacion_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"dw_vacunacion\""
		},
		"dw_vacunacion_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-ucb-sisger-dwvacunacion-13353021.database.windows.net"
		},
		"dw_vacunacion_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dw_vacunacion"
		},
		"dw_vacunacion_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Soria"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI de la cuenta de almacenamiento que contiene las plantillas de ARM vinculadas."
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Token de SAS para la cuenta de almacenamiento que contiene las plantillas de ARM vinculadas"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-ucb-dw-vacunacion-13353021_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"datalake_vacunacion_connectionString": {
						"value": "[parameters('datalake_vacunacion_connectionString')]"
					},
					"dw_vacunacion_password": {
						"value": "[parameters('dw_vacunacion_password')]"
					},
					"dw_vacunacion_properties_typeProperties_server": {
						"value": "[parameters('dw_vacunacion_properties_typeProperties_server')]"
					},
					"dw_vacunacion_properties_typeProperties_database": {
						"value": "[parameters('dw_vacunacion_properties_typeProperties_database')]"
					},
					"dw_vacunacion_properties_typeProperties_userName": {
						"value": "[parameters('dw_vacunacion_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}